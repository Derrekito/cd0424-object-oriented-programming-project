# Generated by diagnostic-picker.nvim — DO NOT EDIT.
# Manual settings belong in .clangd-user.yaml; they are merged in on every apply.

CompileFlags:
  Remove:
    - "-std=*"
    - "-Wall"
    - "-Wextra"
    - "-Wpedantic"
    - "-Weverything"
    - "-Wshadow"
    - "-Wnon-virtual-dtor"
    - "-Wold-style-cast"
    - "-Wcast-align"
    - "-Wunused"
    - "-Woverloaded-virtual"
    - "-Wconversion"
    - "-Wsign-conversion"
    - "-Wmisleading-indentation"
    - "-Wnull-dereference"
    - "-Wdouble-promotion"
    - "-Wformat=2"
    - "-Wimplicit-fallthrough"
    - "-Wlifetime"
  Add:
    - "-std=c++17"
    - "-Wall"
    - "-Wextra"
    - "-Wpedantic"
    - "-Wshadow"
    - "-Wunused"
    - "-Woverloaded-virtual"
    - "-I../include"

Diagnostics:
  ClangTidy:
    Add:
      - bugprone-*
      - clang-analyzer-*
      - cppcoreguidelines-*
      - misc-*
      - modernize-*
      - performance-*
      - readability-*
    Remove:
      - abseil-*
      - android-*
      - boost-*
      - cert-*
      - concurrency-*
      - fuchsia-*
      - fuchsia-trailing-return
      - google-*
      - hicpp-*
      - linuxkernel-must-check-errs
      - llvm-*
      - modernize-use-trailing-return-type
      - mpi-*
      - openmp-*
      - portability-*
      - zircon-*
